# ─────────────────────────────────────────────
#  pdfcleanerx  –  Environment Configuration
#  Copy this file to .env and edit as needed.
# ─────────────────────────────────────────────

# ── Logging ──────────────────────────────────
# Levels: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ── Output ───────────────────────────────────
# Default output directory for generated .md files
OUTPUT_DIR=./output

# ── Heading Detection ─────────────────────────
# Font-size multiplier above body average to qualify as a heading
HEADING_FONT_SIZE_THRESHOLD=1.2

# Minimum / maximum character length for a line to be a heading candidate
HEADING_MIN_LENGTH=3
HEADING_MAX_LENGTH=120

# ── Line-Wrap Cleaner ─────────────────────────
# Characters that signal a line is "complete" (do NOT merge with next)
LINE_TERMINAL_PUNCTUATION=.!?:;

# ── Page-Number Cleaner ───────────────────────
# Enable/disable individual patterns
PAGE_NUMBER_STRIP_STANDALONE=true
PAGE_NUMBER_STRIP_PAGE_N_OF_M=true
PAGE_NUMBER_STRIP_REPEATED_FOOTER=true

# Number of consecutive pages a footer must appear on to be stripped
FOOTER_REPEAT_THRESHOLD=3

# ── Pipeline Feature Flags ────────────────────
# Set any to false to disable that cleaner stage
CLEANER_PAGE_NUMBERS=true
CLEANER_LINE_WRAP=true
CLEANER_WHITESPACE=true
CLEANER_HEADINGS=true
